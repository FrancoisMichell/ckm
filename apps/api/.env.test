# Test environment — points at postgres-test container (port 5433)
NODE_ENV=test
PORT=3001
RUN_MIGRATIONS=false

# Database — test container
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5433
DB_USER=ckm
DB_PASSWORD=ckm
DB_NAME=ckm_test
DB_LOGGING=false

# JWT — fixed test secret (32+ chars, never used in production)
JWT_SECRET=test_secret_that_is_long_enough_32chars_ok
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Security
BCRYPT_SALT_ROUNDS=1

# Features
SWAGGER_ENABLED=false
LOG_LEVEL=error

# CORS
ALLOWED_ORIGIN=http://localhost:5173

# Throttler bypass token — used by e2e helpers to skip the global rate-limit
# on setup/teardown requests. Must be ≥16 chars. Never set in production:
# ConfigService.get('throttle.testBypassToken') returns undefined there and
# the skipIf callback fails closed.
THROTTLE_TEST_BYPASS_TOKEN=test_throttle_bypass_token_for_e2e_only
